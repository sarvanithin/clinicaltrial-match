# Required
ANTHROPIC_API_KEY=your-api-key-here

# Optional overrides (all have defaults)
CTM_TRIALS__PAGE_SIZE=100
CTM_TRIALS__CACHE_TTL_SECONDS=86400
CTM_TRIALS__PARSE_CONCURRENCY=5
CTM_CLAUDE__FAST_MODEL=claude-haiku-4-5-20251001
CTM_CLAUDE__REASONING_MODEL=claude-sonnet-4-6-20251101
CTM_EMBEDDING__MODEL_NAME=all-MiniLM-L6-v2
CTM_EMBEDDING__USE_FAISS=false
CTM_DB__PATH=~/.clinicaltrial_match/data.db
CTM_API__HOST=0.0.0.0
CTM_API__PORT=8000
CTM_API__LOG_LEVEL=INFO
